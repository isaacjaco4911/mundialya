# ============================================================
# MundialYa — variables de entorno
# Copia este archivo a .env.local y completa los valores.
# SIN Supabase configurado, la app corre en MODO DEMO
# (datos de ejemplo en memoria: todo funciona pero no persiste).
# ============================================================

# --- Supabase (https://supabase.com → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clave service_role (SOLO en el servidor, nunca la expongas con NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# --- Panel de administración (/admin) ---
ADMIN_PASSWORD=cambia-esta-clave

# --- Sal para hashear IPs de votos/reseñas (cualquier string aleatorio) ---
IP_HASH_SALT=cambia-esta-sal-aleatoria

# --- URL pública del sitio (para OG images, sitemap, compartir) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
